# ===========================================================
# GLXY Radio — omgeving
# ===========================================================
# Lokaal: kopieer naar .env.local (niet committen).
# Productie (Railway): geen .env.local — zet variabelen in Railway.
# Zie RAILWAY.md voor de volledige deploy-checklist.

# --- Database (PostgreSQL) + Prisma ---
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/glxy?schema=public"

# Railway Postgres:
# - Lokaal ontwikkelen: gebruik variable "DATABASE_PUBLIC_URL" uit het Railway-dashboard
#   (niet de internal host). Vaak vereist Prisma SSL — plak achter de URL:
#   ?sslmode=require
#   Voorbeeld (geen echte credentials):
#   DATABASE_URL="postgresql://postgres:WACHTWOORD@turntable.proxy.rlwy.net:PORT/railway?sslmode=require"
# - Next.js app draait óók op Railway: gebruik de internal connection string
#   (postgres.railway.internal:5432) als DATABASE_URL in die service.

# Optioneel: PRISMA_DEBUG=1 om Prisma-queries/fouten naar de console te loggen

# --- NextAuth ---
NEXTAUTH_SECRET="genereer-met-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Productie: https://glxy-production.up.railway.app (zonder trailing slash)
# Aanbevolen achter Railway proxy:
# AUTH_TRUST_HOST=true

# Optioneel: fallback HLS voor homepage als er geen branding-rij in de DB is
# NEXT_PUBLIC_GLXY_HLS_URL=https://mistserv4.videostreams.nl/hls/camfactor/index.m3u8

# --- Eerste beheerder (eenmalig: prisma db seed met lege User-tabel) ---
ADMIN_BOOTSTRAP_EMAIL="jij@voorbeeld.nl"
ADMIN_BOOTSTRAP_PASSWORD="minstensachttekens"

# --- Optioneel: SMTP voor uitnodigingsmail (zonder SMTP: kopieer link uit admin) ---
# SMTP_HOST=smtp.voorbeeld.nl
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=jij@voorbeeld.nl
# SMTP_PASS=app-wachtwoord
# SMTP_FROM="GLXY <no-reply@voorbeeld.nl>"

# --- Overig ---
# Optioneel: toegangscode voor /monitor (fallback staat ook in code)
# MONITOR_PAGE_CODE=kies_zelf_iets_veiligs
