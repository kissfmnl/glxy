# ===========================================================
# GLXY (KISS stack) — environment variables
# ===========================================================
# Kopieer dit bestand naar .env.local en vul de waarden in.
# Commit .env.local NOOIT naar Git (zorg dat het in .gitignore staat).

# -----------------------------------------------------------
# DATABASE
# -----------------------------------------------------------
# Lokaal: installeer PostgreSQL en maak een database aan met:
#   createdb kissfm
# Voor productie (Railway): kopieer de DATABASE_URL uit het Railway dashboard.
DATABASE_URL="postgresql://user:password@localhost:5432/kissfm"

# Persistent bestanden (favicon-uploads, DJ-foto’s, vacatures, …): map op je volume zodat ze een deploy overleven.
# Voorbeeld Docker: -v /data/kissfm-website:/data/website  →  WEBSITE_FILES_ROOT="/data/website"
# Op die locatie moet een map Website/ staan (of ontstaat bij eerste upload).
# WEBSITE_FILES_ROOT="/pad/naar/persistent/website-root"

# -----------------------------------------------------------
# META WHATSAPP CLOUD API
# -----------------------------------------------------------
# WHATSAPP_VERIFY_TOKEN: Bedenk zelf een willekeurig, lang geheim wachtwoord.
#   Dit voer je in bij: Meta Developers → Jouw App → WhatsApp → Configuratie → Webhook → Verify token.
#   Ons systeem controleert of Meta exact dit token terugstuurt bij endpoint verificatie.
WHATSAPP_VERIFY_TOKEN="WIJZIG_DIT_NAAR_EEN_LANG_GEHEIM_TOKEN"

# WHATSAPP_API_TOKEN: Jouw Meta Permanent Access Token.
#   Te vinden in: Meta Developers → Jouw App → WhatsApp → API Setup → Access Token.
#   Nodig om later berichten te kunnen TERUGSTUREN via de API.
WHATSAPP_API_TOKEN="EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Next-Auth Configuratie
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="lang_geheim_willekeurig_tekenreeks"     # Genereer met: openssl rand -base64 32

# Playlist-log cron (Vercel: zelfde waarde als CRON_SECRET in project settings; anders extern elke minuut GET met Authorization: Bearer …)
CRON_SECRET="willekeurig_geheim_voor_cron"

# Ticketmaster Discovery API key (gratis) voor automatische concert-sync.
# Gebruik in /settings/concerten knop "Nu syncen" of via /api/cron/concert-sync.
# TICKETMASTER_API_KEY=""

# Throwback e-mail notificaties (optioneel; bij nieuwe inzending).
# Zonder SMTP_HOST wordt e-mail verzenden overgeslagen.
# SMTP_HOST="smtp.jouwdomein.nl"
# SMTP_PORT="587"
# SMTP_SECURE="false" # true bij poort 465
# SMTP_USER="smtp-gebruiker"
# SMTP_PASS="smtp-wachtwoord"
# SMTP_FROM="no-reply@kissfm.nl"
# THROWBACK_NOTIFY_TO="throwback@kissfm.nl"
# THROWBACK_MAIL_FROM="throwback@kissfm.nl"

# Optioneel: code voor /monitor pagina (fallback is kissfm123)
MONITOR_PAGE_CODE="kies_een_eenvoudige_monitor_code"

# Optioneel: bezoekers geo lookup (nu via gratis ipapi endpoint zonder key; dit is alleen documentatie)
# IP_GEO_API_KEY=""

# Optioneel: extra accounts met toegang tot /settings/kiss40 (naast ADMIN). Komma- of spatiegescheiden e-mails.
# KISS40_EDITOR_EMAILS="redactie@kissfm.nl"

# WHATSAPP_PHONE_NUMBER_ID: Het Phone Number ID van jouw WhatsApp Business nummer.
#   Te vinden in: Meta Developers → Jouw App → WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID="111111111111111"
