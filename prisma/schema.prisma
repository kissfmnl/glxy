generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  DJ
  ADMIN
  SUPER_ADMIN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(DJ)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  role      Role      @default(DJ)
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email])
}

/// Singleton (id moet altijd 1 zijn) — GLXY kleuren/logo’s/livestream.
model Branding {
  id         Int      @id @default(1)
  primaryHex String   @default("#0b7557")
  accentHex  String   @default("#6d6d6d")
  navyHex    String   @default("#363636")
  yellowHex  String   @default("#ffe200")
  logoUrl    String?
  /// Hero/header-logo als data-URI (overleeft deploy zonder schijf-volume)
  logoDataUri String? @db.Text
  faviconUrl String?
  /// Publiek menu items (volgorde/editable)
  navItems   Json?
  /// Social links voor header icons
  instagramUrl String?
  tiktokUrl    String?
  /// Kleur van de publieke menubalk bovenin
  menuBarHex   String?
  /// Accent rond homepage-video (gradient rand/glow)
  heroVideoFrameHex String?
  /// Balkje “Luister naar”: achtergrond en tekst (hex)
  listenBarBgHex   String?
  listenBarTextHex String?
  /// Zenderkleuren override (id -> bgHex of {bgHex,textHex})
  stationColors Json?
  /// Zenders: naam, subtitel, stream, logo (JSON-array; logo mag data-URI)
  stationsConfig Json?
  /// Mini-player + zenderkaarten + hero-video controls (hex-kleuren JSON)
  playerUi       Json?
  /// Super-admin bewerkbare toelichtingen op admin-pagina’s (JSON)
  adminPortalCopy Json?
  /// Laatste bekende nu-speelt per zender-id (server-side; voor programmering-pagina)
  stationNpSnapshot Json?
  /// Per zender: laatst gedraaide tracks (titel/artiest/tijd) voor JUST PLAYED
  stationPlayHistory Json?
  /// Optionele programmaschema-override (array van slots); anders vaste mock
  programmingSchedule Json?
  homeHlsUrl String   @default("https://mistserv4.videostreams.nl/hls/camfactor/index.m3u8")
  updatedAt  DateTime @updatedAt
}

/// Geüploade afbeeldingen (op schijf onder Website/media/…).
model MediaAsset {
  id          String   @id @default(cuid())
  filename    String
  storagePath String   @unique
  mimeType    String
  sizeBytes   Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}
